# OpenShift secrets template.
# Copy to 01-secrets.yaml, fill in values, apply with: oc apply -f openshift/01-secrets.yaml
# Then IMMEDIATELY delete: rm openshift/01-secrets.yaml
# NEVER commit 01-secrets.yaml to git.
---
apiVersion: v1
kind: Secret
metadata:
  name: frc-db-secret
  namespace: frc-scheduler-server
type: Opaque
stringData:
  POSTGRES_USER: frc
  POSTGRES_PASSWORD: CHANGE_ME_STRONG_PASSWORD
  POSTGRES_DB: frc_scheduler
---
apiVersion: v1
kind: Secret
metadata:
  name: frc-app-secret
  namespace: frc-scheduler-server
type: Opaque
stringData:
  TBA_API_KEY: YOUR_TBA_API_KEY
  FRC_EVENTS_USERNAME: YOUR_FRC_EVENTS_USERNAME
  FRC_EVENTS_TOKEN: YOUR_FRC_EVENTS_TOKEN
---
apiVersion: v1
kind: Secret
metadata:
  name: frc-auth-secret
  namespace: frc-scheduler-server
type: Opaque
stringData:
  JWT_SECRET: CHANGE_ME_RUN_openssl_rand_-hex_32
  BASE_URL: https://YOUR_HOSTNAME
  GOOGLE_CLIENT_ID: ""
  GOOGLE_CLIENT_SECRET: ""
  APPLE_CLIENT_ID: ""
  APPLE_TEAM_ID: ""
  APPLE_KEY_ID: ""
  APPLE_PRIVATE_KEY: ""
