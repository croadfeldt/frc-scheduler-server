# OpenShift secrets template.
# Copy to 01-secrets.yaml, fill in values, then apply:
#   oc apply -f openshift/01-secrets.yaml
# Then IMMEDIATELY delete: rm openshift/01-secrets.yaml
# NEVER commit 01-secrets.yaml to git.
#
# For detailed integration setup instructions (where to get each token,
# what each integration does, what happens when it's missing), see:
#   docs/INTEGRATIONS.md
#
# NOTE: DATABASE_URL must be kept in sync with POSTGRES_* values above it.
# It is stored explicitly because Kubernetes $(VAR) substitution does not
# work when the referenced variable comes from valueFrom: secretKeyRef.
---
apiVersion: v1
kind: Secret
metadata:
  name: frc-db-secret
  namespace: NAMESPACE_PLACEHOLDER
type: Opaque
stringData:
  POSTGRES_USER:     frc
  POSTGRES_PASSWORD: CHANGE_ME_STRONG_PASSWORD
  POSTGRES_DB:       frc_scheduler
  DATABASE_URL:      "postgresql+asyncpg://frc:CHANGE_ME_STRONG_PASSWORD@frc-postgres:5432/frc_scheduler"
---
apiVersion: v1
kind: Secret
metadata:
  name: frc-app-secret
  namespace: NAMESPACE_PLACEHOLDER
type: Opaque
stringData:
  # ── External integrations ──────────────────────────────────────────────
  # See docs/INTEGRATIONS.md for what each does, where to get tokens, and
  # how to verify the integration is working.

  # The Blue Alliance (TBA) — primary source of FRC event/match data.
  # Required for: event picker, team imports, live data, source detection.
  # Get your key at: https://www.thebluealliance.com/account → Read API
  TBA_API_KEY:           YOUR_TBA_API_KEY

  # FRC Events API — official FIRST API, used as fallback when TBA doesn't
  # have an event yet. Optional. Apply at:
  # https://frc-events.firstinspires.org/services/API
  FRC_EVENTS_USERNAME:   YOUR_FRC_EVENTS_USERNAME
  FRC_EVENTS_TOKEN:      YOUR_FRC_EVENTS_TOKEN

  # Nexus for FRC webhooks — receives real-time match queue updates.
  # Required for: queueing pills in /view, "Nexus" data source badge,
  # and the Nexus referral card encouraging users to sign up for
  # notifications. Generate with: openssl rand -hex 32
  # Then configure the SAME value in Nexus's event webhook settings,
  # under header "Nexus-Token". If unset, webhook auth is disabled
  # (acceptable for local dev only — set this in production).
  NEXUS_WEBHOOK_TOKEN:   YOUR_NEXUS_WEBHOOK_TOKEN

  # LLM endpoint for PDF schedule import.
  # Required for: the "Import schedule from PDF" button in the editor.
  # Any OpenAI-compatible endpoint works — vLLM, llama.cpp's llama-server,
  # or commercial APIs. Tested primarily against llama.cpp with Qwen3-32B.
  # When unset, the PDF import button is hidden and only TBA/manual paths
  # are available. Privacy: PDFs are sent only to the configured endpoint.
  LLM_ENDPOINT:          ""    # e.g. http://vis.example.com:8000/v1
  LLM_MODEL:             ""    # e.g. qwen, llama-3.3-70b-instruct
  LLM_API_KEY:           ""    # leave empty for self-hosted llama.cpp/vLLM

  # Statbotics: no configuration needed — public read-only API.
  # The /api/statbotics/* endpoints work out of the box.

  # Deep-links to TBA, Statbotics, FRC Events from per-team and per-event
  # panels: no configuration needed — pure URL construction from event key.
---
apiVersion: v1
kind: Secret
metadata:
  name: frc-auth-secret
  namespace: NAMESPACE_PLACEHOLDER
type: Opaque
stringData:
  JWT_SECRET:            CHANGE_ME_RUN_openssl_rand_-hex_32
  BASE_URL:              https://YOUR_HOSTNAME
  GOOGLE_CLIENT_ID:      ""
  GOOGLE_CLIENT_SECRET:  ""
  APPLE_CLIENT_ID:       ""
  APPLE_TEAM_ID:         ""
  APPLE_KEY_ID:          ""
  APPLE_PRIVATE_KEY:     ""
