# ─────────────────────────────────────────────────────────────────────────────
# FRC Match Scheduler — OpenShift site configuration
# Copy this file to config.env and fill in your values.
# config.env is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Namespace ─────────────────────────────────────────────────────────────────
# OpenShift namespace / project all resources are deployed into.
NAMESPACE=frc-scheduler-server

# ── Git repository ────────────────────────────────────────────────────────────
# Your fork of this repository — used by the BuildConfig source and the
# git-poll CronJob to detect new commits.
GIT_REPO_URL=https://github.com/YOUR_ORG/YOUR_REPO.git
GIT_BRANCH=main

# ── Hostname ──────────────────────────────────────────────────────────────────
# Public FQDN of the app (must have DNS pointing to your MetalLB VIP or ingress).
APP_HOSTNAME=frc-scheduler.example.com

# ── TLS ───────────────────────────────────────────────────────────────────────
# cert-manager ClusterIssuer name. Verify with: oc get clusterissuer
CERT_ISSUER=letsencrypt-production

# ── MetalLB ───────────────────────────────────────────────────────────────────
# Specific IP to request from MetalLB. Leave blank to auto-assign from pool.
METALLB_IP=

# ── Kubernetes service CIDR ───────────────────────────────────────────────────
# The internal service network used by the OpenShift API server (172.30.0.1).
# Build pods must be able to reach this to report build status.
# Default for most OpenShift clusters is 172.30.0.0/16.
# Check yours with: oc get network cluster -o jsonpath='{.spec.serviceNetwork}'
K8S_SERVICE_CIDR=172.30.0.0/16

# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=8443
CPU_WORKERS=12
WEB_WORKERS=1
