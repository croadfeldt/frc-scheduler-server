# ── OpenShift site-specific configuration ─────────────────────────────────────
# Copy this file:
#   cp openshift/config.env.example openshift/config.env
# Fill in your values. config.env is gitignored and never committed.

# Your Git repository URL (used by BuildConfig and build-poll CronJob)
GIT_REPO_URL=https://github.com/YOUR_ORG/YOUR_REPO.git

# Public hostname for the scheduler
# Must have DNS pointing at your MetalLB VIP before cert issuance will succeed
APP_HOSTNAME=your-scheduler.example.com

# Your cert-manager ClusterIssuer name
# Check available issuers: oc get clusterissuer
CERT_ISSUER=letsencrypt-prod

# MetalLB IP to assign to the LoadBalancer Service
# Leave blank to use pool default, or set a specific IP from your pool
METALLB_IP=
