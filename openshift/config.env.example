# Site-specific OpenShift configuration.
# Copy to config.env and fill in your values. This file is gitignored.

# Your fork of this repository
GIT_REPO_URL=https://github.com/YOUR_ORG/YOUR_REPO.git

# Public FQDN of the app (must have DNS → MetalLB VIP)
APP_HOSTNAME=frc-scheduler.example.com

# cert-manager ClusterIssuer name — verify with: oc get clusterissuer
CERT_ISSUER=letsencrypt-production

# Optional: MetalLB specific IP (leave blank to use pool auto-assign)
METALLB_IP=
