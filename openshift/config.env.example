# ─────────────────────────────────────────────────────────────────────────────
# FRC Match Scheduler — OpenShift site configuration
# Copy this file to config.env and fill in your values.
# config.env is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Namespace ─────────────────────────────────────────────────────────────────
# OpenShift namespace / project all resources are deployed into.
NAMESPACE=frc-scheduler-server

# ── Git repository ────────────────────────────────────────────────────────────
# Your fork of this repository — used by the BuildConfig source and the
# git-poll CronJob to detect new commits.
GIT_REPO_URL=https://github.com/YOUR_ORG/YOUR_REPO.git
GIT_BRANCH=main

# ── Hostname ──────────────────────────────────────────────────────────────────
# Public FQDN of the app. DNS must point to METALLB_IP.
APP_HOSTNAME=frc-scheduler.example.com

# ── TLS ───────────────────────────────────────────────────────────────────────
# cert-manager ClusterIssuer name. Verify with: oc get clusterissuer
CERT_ISSUER=letsencrypt-production

# ── MetalLB ───────────────────────────────────────────────────────────────────
# Specific IP to request from MetalLB for the LoadBalancer service.
# Must be an available IP in the METALLB_POOL address pool.
# DNS for APP_HOSTNAME must point to this IP.
# Check available pools with: oc get ipaddresspool -n metallb-system
METALLB_IP=YOUR_METALLB_IP
METALLB_POOL=YOUR_METALLB_POOL

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# Defaults to https://${APP_HOSTNAME} if left blank. Override here if you also
# expose the app via the MetalLB LoadBalancer (port APP_PORT) or any other URL.
# Example: https://frc-scheduler.example.com,https://10.0.0.100:8088
ALLOWED_ORIGINS=

# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=8443
CPU_WORKERS=4
WEB_WORKERS=1
