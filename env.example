# Copy this to .env and fill in your values
# docker-compose reads .env automatically

# Get a free TBA API key at https://www.thebluealliance.com/account
TBA_API_KEY=your_key_here

# FRC Events API — register at https://frc-events.firstinspires.org/services/API
# Username is your FIRST account username; token is generated on the same page.
FRC_EVENTS_USERNAME=
FRC_EVENTS_TOKEN=

# Number of CPU workers for parallel scheduling (0 = auto = os.cpu_count())
CPU_WORKERS=0

# ── Container runtime ───────────────────────────────────────────────────────────
# Port uvicorn listens on — use 8080+ for rootless (no CAP_NET_BIND_SERVICE needed)
APP_PORT=8080
# WEB_WORKERS: uvicorn process count. 1=single user, 2-4=multi-user.
# Each worker spawns its own ProcessPoolExecutor — scale with available CPU.
WEB_WORKERS=1
# UID/GID the process runs as — set to $(id -u):$(id -g) to match the host user
# for rootless Podman, or leave as 1001:0 for standard OCI rootless
PUID=1000
PGID=1000

# ── Authentication ─────────────────────────────────────────────────────────────
# JWT secret — change to a long random string in production
JWT_SECRET=change-me-in-production

# Public base URL of this server (used for OAuth callback URLs)
BASE_URL=http://localhost:8080

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BASE_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In — configure at https://developer.apple.com/account/resources/identifiers
# Service ID (web), redirect URI: ${BASE_URL}/auth/apple/callback
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=   # PEM key content; replace newlines with \n
