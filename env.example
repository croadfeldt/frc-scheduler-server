# FRC Match Scheduler — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_USER=frc
POSTGRES_PASSWORD=changeme
POSTGRES_DB=frc_scheduler

# ── External APIs ──────────────────────────────────────────────────────────────
TBA_API_KEY=
FRC_EVENTS_USERNAME=
FRC_EVENTS_TOKEN=

# ── Container runtime ──────────────────────────────────────────────────────────
APP_PORT=8080
WEB_WORKERS=1
CPU_WORKERS=0
PUID=1000
PGID=1000

# ── TLS (optional) ─────────────────────────────────────────────────────────────
SSL_CERTFILE=
SSL_KEYFILE=
TLS_DIR=

# ── Security ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=*
JWT_SECRET=change-me-in-production
BASE_URL=http://localhost:8080

# ── Authentication (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
