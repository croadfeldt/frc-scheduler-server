# FRC Match Scheduler — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_USER=frc
POSTGRES_PASSWORD=changeme
POSTGRES_DB=frc_scheduler

# ── External APIs ──────────────────────────────────────────────────────────────
# TBA API key — free at https://www.thebluealliance.com/account
TBA_API_KEY=

# FRC Events API — https://frc-events.firstinspires.org/services/API
FRC_EVENTS_USERNAME=
FRC_EVENTS_TOKEN=

# ── Container runtime ──────────────────────────────────────────────────────────
# Port uvicorn listens on (use 8443 when TLS is enabled)
APP_PORT=8080
# Number of uvicorn worker processes (1=single-user, 2-4=multi-user)
WEB_WORKERS=1
# CPU workers for parallel scheduling (0 = auto = os.cpu_count())
CPU_WORKERS=0
# UID/GID the process runs as — set to $(id -u):$(id -g) for rootless Podman
PUID=1000
PGID=1000

# ── TLS (optional) ─────────────────────────────────────────────────────────────
# Leave blank to run plain HTTP (default for local dev).
# Set both to enable HTTPS. Paths are inside the container (/certs/ by default).
# Also set APP_PORT=8443 and TLS_DIR=./tls when enabling TLS.
#
# Generate a self-signed cert for local dev:
#   mkdir tls
#   openssl req -x509 -newkey rsa:4096 -nodes -days 365 \
#     -keyout tls/server.key -out tls/server.crt -subj "/CN=localhost"
SSL_CERTFILE=
SSL_KEYFILE=
# Host directory containing your cert/key files (mounted as /certs in container)
TLS_DIR=

# ── Security ───────────────────────────────────────────────────────────────────
# CORS allowed origins (comma-separated). Use * for local dev only.
ALLOWED_ORIGINS=*
# JWT secret — change to a long random string: openssl rand -hex 32
JWT_SECRET=change-me-in-production
# Public base URL (used for OAuth redirect URIs)
BASE_URL=http://localhost:8080

# ── Authentication (optional) ──────────────────────────────────────────────────
# Google OAuth — https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI: ${BASE_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In — https://developer.apple.com/account/resources/identifiers
#   Service ID redirect URI: ${BASE_URL}/auth/apple/callback
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=   # PEM key — replace newlines with \n
